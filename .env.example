PORT=3001
NODE_ENV=development

# Public frontend origin used for CORS and Stripe redirect URLs.
FRONTEND_URL=http://localhost:5173

# MySQL connection string used by Drizzle and the API routes.
DATABASE_URL=mysql://user:password@localhost:3306/buildlevel

# Generate strong secrets before production use.
JWT_SECRET=replace-with-a-long-random-secret

# Format: salt:hex_scrypt_hash
# Example generator:
# node -e "const {randomBytes,scryptSync}=require('crypto'); const p=process.argv[1]; const s=randomBytes(16).toString('hex'); console.log(`${s}:${scryptSync(p,s,64).toString('hex')}`)" "your-password"
ADMIN_PASSWORD_HASH=replace-with-generated-admin-password-hash

# Required for Stripe checkout routes.
STRIPE_SECRET_KEY=sk_test_replace_me

# Required in production for verified Stripe webhooks.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
